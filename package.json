{
  "name": "@putdotio/cli",
  "version": "1.0.0",
  "description": "Agent-first CLI for the put.io API.",
  "homepage": "https://github.com/putdotio/putio-cli#readme",
  "bugs": {
    "url": "https://github.com/putdotio/putio-cli/issues"
  },
  "license": "MIT",
  "author": "put.io <ui@put.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/putdotio/putio-cli.git"
  },
  "bin": {
    "putio": "./dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./bin": "./dist/bin.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "build:sea": "node ./scripts/build-sea.mjs",
    "check": "vp check .",
    "coverage": "vitest run --coverage",
    "dev": "vp pack --watch",
    "smoke:pack": "node ./scripts/smoke-packed-install.mjs",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build",
    "verify:sea": "node ./scripts/verify-sea.mjs",
    "verify": "pnpm run check && pnpm run build && pnpm run test && pnpm run coverage"
  },
  "dependencies": {
    "@effect/cli": "^0.73.2",
    "@effect/platform": "0.94.5",
    "@effect/platform-node": "0.104.1",
    "@putdotio/sdk": "^9.1.0",
    "cli-table3": "^0.6.5",
    "effect": "3.19.19",
    "i18next": "^25.5.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.0",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5.9.3",
    "vite-plus": "0.1.11",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "packageManager": "pnpm@10.32.1"
}
